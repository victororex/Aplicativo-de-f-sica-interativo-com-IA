APP_NAME=API - Aplicativo de Fisica com IA
APP_ENV=development
APP_DEBUG=false
API_VERSION=1.0.0

# Em desenvolvimento pode usar SQLite. Em producao, troque a arquitetura para PostgreSQL.
DATABASE_PATH=data/fisica_ia.sqlite3
UPLOAD_DIR=data/uploads

# Troque obrigatoriamente em producao.
JWT_SECRET_KEY=troque-por-uma-chave-grande-e-secreta
JWT_EXPIRE_MINUTES=120

# Separe origens por virgula. Em producao, deixe apenas o app/site permitido.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:8000
MAX_UPLOAD_MB=10
FORMULA_MAX_UPLOAD_MB=8
FORMULA_MAX_DIMENSION=2048

# IA
USE_MOCK_AI=true
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
OCR_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=60
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin

# Voz clonada local: MeloTTS + OpenVoice V2
TTS_ENGINE=edge_openvoice
OPENVOICE_CHECKPOINTS_DIR=checkpoints_v2
VOICE_REFERENCE_DIR=voices
VOICE_TMP_DIR=tmp
MELOTTS_LANGUAGE=ES
MELOTTS_SPEAKER=
MELOTTS_SPEED=1.0
