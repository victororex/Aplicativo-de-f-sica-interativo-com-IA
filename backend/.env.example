APP_NAME=API - Aplicativo de Fisica com IA
APP_ENV=development
APP_DEBUG=false
API_VERSION=1.0.0

# Em desenvolvimento pode usar SQLite. Em producao, troque a arquitetura para PostgreSQL.
DATABASE_PATH=data/fisica_ia.sqlite3
UPLOAD_DIR=data/uploads

# Troque obrigatoriamente em producao.
JWT_SECRET_KEY=troque-por-uma-chave-grande-e-secreta
JWT_EXPIRE_MINUTES=120

# Separe origens por virgula. Em producao, deixe apenas o app/site permitido.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:8000
MAX_UPLOAD_MB=10

# IA
USE_MOCK_AI=true
OPENAI_API_KEY=
MODEL_NAME=gpt-4o-mini
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
